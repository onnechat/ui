{
  "name": "@shiddo/ui",
  "version": "0.1.0",
  "description": "Biblioteca de componentes React para Shiddo",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "watch": "tsup --watch",
    "dev": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\"",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "bun run build",
    "chromatic": "bunx chromatic --project-token=your-project-token"
  },
  "keywords": [
    "react",
    "components",
    "ui",
    "design-system",
    "typescript",
    "storybook"
  ],
  "author": "Shiddo Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shiddo/ui.git"
  },
  "bugs": {
    "url": "https://github.com/shiddo/ui/issues"
  },
  "homepage": "https://github.com/shiddo/ui#readme",
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.4.4",
